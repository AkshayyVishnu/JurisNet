# Copy to .env and fill in real values. .env is gitignored.

# ── Embeddings ──
VOYAGE_API_KEY=your-voyage-key-here

# ── Agent LLMs — multiple keys, rotated round-robin (see llm_keys.py) ──
# Convention: the FIRST key is the bare name, then numbered from 2 (no _1 suffix).
# Add as many as you have; empties/gaps are skipped by the loader.
# Groq (up to 14): GROQ_API_KEY, GROQ_API_KEY2, ... GROQ_API_KEY14
GROQ_API_KEY=your-groq-key-1
GROQ_API_KEY2=your-groq-key-2
# ... up to GROQ_API_KEY14

# Google/Gemini (up to 20): GOOGLE_API_KEY, GOOGLE_API_KEY2, ... GOOGLE_API_KEY20
GOOGLE_API_KEY=your-google-key-1
GOOGLE_API_KEY2=your-google-key-2
# ... up to GOOGLE_API_KEY20

# ── Stores ──
# Qdrant Cloud: cluster endpoint + API key (leave key blank for local Docker).
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
# Neo4j Aura: neo4j+s:// connection URI (NOT the https query URL).
NEO4J_URI=neo4j+s://your-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password
